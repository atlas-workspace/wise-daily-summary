# WISE Dashboard Template Environment Variables
# Copy to .env and fill in real values

# Server
PORT=3000
# Set NODE_ENV=production for deployments. In production the server refuses
# to start unless COOKIE_SECRET is set to a random string of 32+ characters,
# cookies get the Secure flag, and /simulate/* routes are disabled.
#NODE_ENV=production

# IAM Authentication
# Production login endpoint: https://unis.item.com/api/wms-bam/auth/login-by-password
IAM_BASE_URL=https://unis.item.com/api/wms-bam
IAM_LOGIN_PATH=/auth/login-by-password

# Session
# Random secret for signing session cookies (required, 32+ chars, in production)
COOKIE_SECRET=replace-with-random-32-char-string

# Login rate limiting (per client IP, fixed window)
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# WMS API
# Gateway base URL (service paths like /wms-bam/... are appended)
WMS_BASE_URL=https://unis.item.com/api
# Bearer token for the background poller (server-to-server mode).
# If blank the poller does not start (use MOCK_WMS=true for local testing).
WMS_AUTH_TOKEN=
TENANT_ID=LT
FACILITY_ID=LT_ORG-8125

# YMS API
YMS_BASE_URL=https://unis.item.com/api

# TMS/FMS API health check
# Base gateway URL; TMS_HEALTH_PATH is intentionally read-only/non-mutating.
TMS_BASE_URL=https://unis.item.com/api
TMS_HEALTH_PATH=/wms-bam/v1/web/user/info

# Ticket API health check
# Base gateway URL; uses GET /v1/iam/ticket/priorities/list (read-only).
# Auth: IAM bearer token from the user session (same as WMS/YMS/TMS).
# No separate TICKET_API_KEY — /v1/iam/... endpoints rely solely on the IAM token.
TICKET_BASE_URL=https://ticket.item.com/api/item-tickets

# Timezone (used as Item-Time-Zone header for YMS/TMS requests)
TIMEZONE=America/Los_Angeles

# Poller (background WebSocket bridge — runs independently of frontend)
POLL_INTERVAL_MS=5000
POLL_PAGE_SIZE=50

# WebSocket auth
# /ws requires either a signed dashboard session cookie (browser clients) or
# this shared key (server-to-server consumers, via ?key=... or
# Authorization: Bearer ...). Leave blank to allow session-cookie auth only.
WS_AUTH_KEY=

# Modes
MOCK_WMS=false
MARK_EVENTS_PROCESSED=false
# POST /simulate/order-shipped is enabled outside production by default.
# Uncomment to override explicitly.
#ENABLE_SIMULATE_ROUTES=false
# Return full diagnostics to frontend on auth/WMS/YMS/TMS/Ticket failures.
# Defaults to false (off); enable only while debugging.
AUTH_DEBUG_RESPONSES=true

# Logging
LOG_LEVEL=info
